# Environment
.env
.env.*
!.env.example
*.pyc
__pycache__/
*.pyo

# Logs
logs/
*.log

# Data
data/*.csv
data/*.json
# Auto-tuner / dashboard overlays: per-host runtime overrides that get
# deep-merged on top of config/{settings,strategies}.yaml. Keeping them
# off-repo prevents the merge-conflict cascade that hit session 10.
data/auto-tuner-overrides.yaml
data/strategy-tuner-overrides.yaml
# Per-strategy slippage rolling buffer (Wave 4). Per-host runtime state;
# no point versioning. Re-creates from an empty buffer on first record.
data/slippage_tracker.json

# IDE
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Auto-deploy runtime state (per-VPS; body = last-deployed SHA)
.last-deploy

# Local-only data pulls from scripts/fetch_review_data.py — never committed.
.review/
