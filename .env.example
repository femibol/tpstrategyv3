# ============================================
# ALGO TRADING BOT - ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values
# ============================================
# Professional IBKR-only architecture:
# - IBKR: sole broker (data + scanning + execution + bracket stops)
# - Claude API: pre-trade validation + self-improvement
# - TradingView: signal webhooks (optional)
# ============================================

# === MODE ===
# paper = Paper trading (NO real money) - START HERE
# live = Real money trading
TRADING_MODE=paper

# === IBKR (Interactive Brokers) — REQUIRED ===
# IB Gateway runs headless in the docker-compose stack.
# The bot connects to the 'ib-gateway' container via docker network.
IBKR_HOST=ib-gateway
IBKR_PORT=4002
# 4002 = IB Gateway Paper (recommended for testing)
# 4001 = IB Gateway Live
IBKR_CLIENT_ID=1

# === IB Gateway Docker Auto-Login — REQUIRED ===
# IBC auto-logs in using these credentials every restart.
# Weekly 2FA approval on IBKR mobile app (Sunday night).
IB_USERNAME=
IB_PASSWORD=
IB_TRADING_MODE=paper
# VNC access for debugging (SSH tunnel only, not exposed to internet)
VNC_PASSWORD=changeme

# === Claude API — REQUIRED (AI brain for trade decisions) ===
# Get key: https://console.anthropic.com/settings/keys
# Used for pre-trade validation and post-trade self-improvement
ANTHROPIC_API_KEY=

# === Dashboard — REQUIRED ===
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5000
DASHBOARD_SECRET_KEY=change-this-to-random-string

# === TradingView Webhook (OPTIONAL) ===
# Secret for validating incoming TradingView alert webhooks
# Leave blank if not using TradingView alerts
TRADINGVIEW_WEBHOOK_SECRET=

# === Discord Notifications (OPTIONAL) ===
# Discord webhook for trade alerts to your phone
# Leave blank if you don't want Discord alerts
DISCORD_WEBHOOK_URL=

# === News API (OPTIONAL) ===
# Get free key: https://newsapi.org/
# Used for bearish catalyst detection on open positions
NEWS_API_KEY=

# === Google Sheets Logging (OPTIONAL) ===
# Logs all trades + daily summaries to a shared spreadsheet
# Leave blank if not using Google Sheets
GOOGLE_SHEETS_CREDENTIALS=
GOOGLE_SHEETS_SPREADSHEET_ID=

# === Email Alerts (OPTIONAL) ===
# Leave all blank if not using email
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL=

# === VPS MCP — OPTIONAL (Claude Code remote ops) ===
# Used by tools/vps_mcp.py — exposes narrow tools to Claude Code:
# vps_status, vps_logs, vps_grep_logs, vps_disk, vps_read_file (read-only)
# vps_restart_service, vps_git_pull (mutating — Claude Code prompts on first call)
# Set in your local shell or .env if you want VPS access from Claude Code sessions.
VPS_HOST=
VPS_USER=root
VPS_SSH_KEY=
VPS_PROJECT_DIR=/root/tpstrategyv3
