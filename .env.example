# ============================================
# ALGO TRADING BOT - ENVIRONMENT VARIABLES
# Copy this to .env and fill in your values
# ============================================

# === MODE ===
# paper = Paper trading (NO real money) - START HERE
# live = Real money trading
TRADING_MODE=paper

# === IBKR (Interactive Brokers) ===
# TWS or IB Gateway must be running
IBKR_HOST=127.0.0.1
IBKR_PORT=7497
# 7497 = TWS Paper Trading
# 7496 = TWS Live Trading
# 4002 = IB Gateway Paper
# 4001 = IB Gateway Live
IBKR_CLIENT_ID=1

# === TradersPost ===
TRADERSPOST_WEBHOOK_URL=
TRADERSPOST_API_KEY=

# === TradingView ===
# Webhook secret for verifying incoming alerts
TRADINGVIEW_WEBHOOK_SECRET=your_secret_here

# === Notifications ===
# Discord webhook for trade alerts
DISCORD_WEBHOOK_URL=
# Email alerts (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL=

# === Dashboard ===
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=5000
DASHBOARD_SECRET_KEY=change-this-to-random-string
